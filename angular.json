            ],
            "styles": [
              "projects/backoffice/src/styles.scss"
            ],
            "scripts": []
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "96966467-ab07-4e9e-bfa6-da1c60fa4c4f"
  }
}
